rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isStaff() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "team"];
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /inventory/{inventoryId} {
      allow read, create, update, delete: if isStaff();
    }

    match /inventoryTransactions/{transactionId} {
      allow read, create, update, delete: if isStaff();
    }

    match /manualSales/{saleId} {
      allow read, create, update, delete: if isStaff();
    }

    match /deliveryChallans/{challanId} {
      allow read, create, update, delete: if isStaff();
    }

    match /quoteRequests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
